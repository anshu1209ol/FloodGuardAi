# This file specifies files and directories that should be ignored when
# deploying to Google Cloud.

# Exclude git directory and metadata
.git/
.gitignore

# Exclude virtual environments
.venv/
venv/
ENV/
env/

# Exclude python cache
__pycache__/
*.pyc

# Exclude local env files
.env
.env.*

# Exclude datasets and notebooks (kept locally only)
flood_prediction.csv
test.csv
rainfall in india 1901-2015.csv
flood.csv
district wise rainfall normal.csv
sample_submission.csv
*.ipynb
kaggle.json

# Exclude training and helper scripts (kept locally only)
part1_training.py
train_model.py
train_advanced_model.py
sanity_check.py
simulate.py

# Exclude node modules and build artifacts
node_modules/
dist/
build/
